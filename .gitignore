## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/
out/

# Visual Studio cache/options directory
.vs/

# Rider
.idea/

# VS Code
.vscode/

# Azure
.publishsettings
azureSettings.json

# Logs
*.log

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# IIS Express
iisexpress/

# SQL Server files
*.mdf
*.ldf

# Entity Framework
Migrations/

# NuGet
*.nupkg
packages/
!packages/build/
*.snupkg

# Node modules (if frontend exists)
node_modules/

# Environment files
.env
.env.*

# App settings secrets
appsettings.Development.json
secrets.json

# Publish output
publish/
wwwroot/dist/

# OS generated files
.DS_Store
Thumbs.db

# Resharper
_ReSharper*/
*.DotSettings.user

# Test Results
TestResults/

# Coverage
coverage/
*.coverage
*.coveragexml

# Azure Functions
local.settings.json

# Docker
docker-compose.override.yml